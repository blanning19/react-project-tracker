---
import "../styles/global.css";

const { components, currentSlug, title } = Astro.props;

const allComps = Object.values(components) as any[];

const PAGE_NAMES = new Set([
  "Home", "About", "Login", "Create", "DashboardPage",
]);

const LAYOUT_NAMES = new Set([
  "App", "Navbar", "AuthProvider", "RequireAuth", "ThemeToggle",
]);

const isViewName = (name: string) =>
  name.endsWith("View") || name.endsWith("PageView");

function categorise(comp: any): string {
  if (comp.isHook)                                          return "hook";
  if (PAGE_NAMES.has(comp.name))                            return "page";
  if (LAYOUT_NAMES.has(comp.name))                          return "layout";
  if (isViewName(comp.name) && comp.isComponent)            return "view";
  if (comp.isComponent && comp.file.includes("/views/"))    return "view";
  if (comp.isComponent)                                     return "view";
  if (comp.file.includes("/controllers/"))                  return "controller";
  if (comp.file.includes("/models/") ||
      comp.name.includes("ViewModel"))                      return "model";
  if (comp.file.includes("/utils/"))                        return "util";
  return "other";
}

const pages       = allComps.filter(c => categorise(c) === "page");
const views       = allComps.filter(c => categorise(c) === "view");
const layout      = allComps.filter(c => categorise(c) === "layout");
const hooks       = allComps.filter(c => categorise(c) === "hook");
const controllers = allComps.filter(c => categorise(c) === "controller");
const models      = allComps.filter(c => categorise(c) === "model");
const utils       = allComps.filter(c => categorise(c) === "util");
const other       = allComps.filter(c => categorise(c) === "other");

const sections = [
  { label: "Pages",       items: pages },
  { label: "Views",       items: views },
  { label: "Layout",      items: layout },
  { label: "Hooks",       items: hooks },
  { label: "Controllers", items: controllers },
  { label: "Models",      items: models },
  { label: "Utils",       items: utils },
  { label: "Other",       items: other },
].filter(s => s.items.length > 0);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Source Docs</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <div class="shell">

    <nav class="nav">
      <div class="nav-header">
        <span class="nav-logo">Source Docs</span>
        <span class="nav-title">ICT Dashboard</span>
      </div>

      <a
        href="/"
        class={`nav-item ${!currentSlug ? "active" : ""}`}
        style="margin-top: 8px; font-weight: 600;"
      >
        Overview
      </a>

      {sections.map(section => (
        <div>
          <div class="nav-section-label">{section.label}</div>
          {section.items.map(comp => (
            <a
              href={`/${comp.name}/`}
              class={`nav-item ${currentSlug === comp.name ? "active" : ""}`}
            >
              {comp.name}
            </a>
          ))}
        </div>
      ))}
    </nav>

    <main class="main">
      <slot />
    </main>

  </div>
</body>
</html>
