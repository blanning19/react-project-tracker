# Django
DJANGO_SECRET_KEY=dev-please-change-this-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC
DJANGO_JWT_SIGNING_KEY=change-me-to-a-long-random-string-at-least-32-chars

# Postgres
POSTGRES_DB=myappdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=*******
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: enable best-practice cookie refresh
# DJANGO_AUTH_REFRESH_COOKIE=1
# CSRF_TRUSTED_ORIGINS=http://localhost:5173
