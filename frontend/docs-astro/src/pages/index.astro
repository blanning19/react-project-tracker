---
import Layout from "../layouts/Layout.astro";
import data from "../data/components.json";

const components = data.components;
const allComps   = Object.values(components) as any[];

const componentCount = allComps.filter(c => c.isComponent).length;
const hookCount      = allComps.filter(c => c.isHook).length;
const viewPanelCount = allComps.reduce((n, c) => n + (c.viewPanels?.length ?? 0), 0);
const helperCount    = allComps.reduce((n, c) => n + (c.internalHelpers?.length ?? 0), 0);

const PAGE_NAMES = new Set([
  "Home", "About", "Login", "Create", "DashboardPage",
]);

const LAYOUT_NAMES = new Set([
  "App", "Navbar", "AuthProvider", "RequireAuth", "ThemeToggle",
]);

const isViewName = (name: string) =>
  name.endsWith("View") || name.endsWith("PageView");

function categorise(comp: any): string {
  if (comp.isHook)                                          return "hook";
  if (PAGE_NAMES.has(comp.name))                            return "page";
  if (LAYOUT_NAMES.has(comp.name))                          return "layout";
  if (isViewName(comp.name) && comp.isComponent)            return "view";
  if (comp.isComponent && comp.file.includes("/views/"))    return "view";
  if (comp.isComponent)                                     return "view";
  if (comp.file.includes("/controllers/"))                  return "controller";
  if (comp.file.includes("/models/") ||
      comp.name.includes("ViewModel"))                      return "model";
  if (comp.file.includes("/utils/"))                        return "util";
  return "other";
}

const groups = [
  { label: "Pages",       items: allComps.filter(c => categorise(c) === "page") },
  { label: "Views",       items: allComps.filter(c => categorise(c) === "view") },
  { label: "Layout",      items: allComps.filter(c => categorise(c) === "layout") },
  { label: "Hooks",       items: allComps.filter(c => categorise(c) === "hook") },
  { label: "Controllers", items: allComps.filter(c => categorise(c) === "controller") },
  { label: "Models",      items: allComps.filter(c => categorise(c) === "model") },
  { label: "Utils",       items: allComps.filter(c => categorise(c) === "util") },
  { label: "Other",       items: allComps.filter(c => categorise(c) === "other") },
].filter(g => g.items.length > 0);
---

<Layout components={components} title="Overview">

  <div class="breadcrumb">
    <span>Source Docs</span>
  </div>

  <div class="comp-header">
    <div class="comp-name" style="font-size: 1.6em;">ICT Dashboard</div>
    <div class="comp-desc">
      Auto-generated from source. Every component, hook, utility, and internal
      helper — extracted directly from inside your function bodies.
      Last parsed: {new Date(data.generatedAt).toLocaleString()}.
    </div>
  </div>

  <div class="stats-bar">
    <div class="stat">
      <div class="stat-value">{data.totalFiles}</div>
      <div class="stat-label">Files</div>
    </div>
    <div class="stat">
      <div class="stat-value">{componentCount}</div>
      <div class="stat-label">Components</div>
    </div>
    <div class="stat">
      <div class="stat-value">{hookCount}</div>
      <div class="stat-label">Hooks</div>
    </div>
    <div class="stat">
      <div class="stat-value">{viewPanelCount}</div>
      <div class="stat-label">View Panels</div>
    </div>
    <div class="stat">
      <div class="stat-value">{helperCount}</div>
      <div class="stat-label">Internal Helpers</div>
    </div>
  </div>

  {groups.map(group => (
    <div class="section">
      <div class="overview-section-title">{group.label}</div>
      <div class="index-grid">
        {group.items.map(comp => (
          <a href={`/${comp.name}/`} class="index-card">
            <div class="index-card-name">{comp.name}</div>
            <div class="index-card-file">{comp.file}</div>
            {comp.jsDoc?.description && (
              <div class="index-card-desc">
                {comp.jsDoc.description.slice(0, 100)}
                {comp.jsDoc.description.length > 100 ? "…" : ""}
              </div>
            )}
            {comp.viewPanels?.length > 0 && (
              <div style="margin-top: 8px;">
                <span class="badge badge-panel">
                  {comp.viewPanels.reduce((n: number, p: any) => n + p.children.length, 0)} panels
                </span>
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  ))}

</Layout>
