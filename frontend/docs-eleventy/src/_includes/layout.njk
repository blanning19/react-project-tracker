<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} — Source Docs</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/global.css" />
</head>
<body>
<div class="shell">

  <nav class="nav">
    <div class="nav-header">
      <span class="nav-logo">Source Docs</span>
      <span class="nav-title">{{ components.generatedAt | dateFormat if components.generatedAt }}</span>
    </div>

    <a href="/" class="nav-item {% if currentSlug == null %}active{% endif %}" style="margin-top:8px;font-weight:600;">
      Overview
    </a>

    {% set allComps = components.components | values %}

    {% set pageComps = allComps | byCategory("page") %}
    {% if pageComps.length %}
      <div class="nav-section-label">Pages</div>
      {% for comp in pageComps %}
        <a href="/components/{{ comp.name }}/" class="nav-item {% if currentSlug == comp.name %}active{% endif %}">{{ comp.name }}</a>
      {% endfor %}
    {% endif %}

    {% set viewComps = allComps | byCategory("view") %}
    {% if viewComps.length %}
      <div class="nav-section-label">Views</div>
      {% for comp in viewComps %}
        <a href="/components/{{ comp.name }}/" class="nav-item {% if currentSlug == comp.name %}active{% endif %}">{{ comp.name }}</a>
      {% endfor %}
    {% endif %}

    {% set layoutComps = allComps | byCategory("layout") %}
    {% if layoutComps.length %}
      <div class="nav-section-label">Layout</div>
      {% for comp in layoutComps %}
        <a href="/components/{{ comp.name }}/" class="nav-item {% if currentSlug == comp.name %}active{% endif %}">{{ comp.name }}</a>
      {% endfor %}
    {% endif %}

    {% set hookComps = allComps | byCategory("hook") %}
    {% if hookComps.length %}
      <div class="nav-section-label">Hooks</div>
      {% for comp in hookComps %}
        <a href="/components/{{ comp.name }}/" class="nav-item {% if currentSlug == comp.name %}active{% endif %}">{{ comp.name }}</a>
      {% endfor %}
    {% endif %}

    {% set ctrlComps = allComps | byCategory("controller") %}
    {% if ctrlComps.length %}
      <div class="nav-section-label">Controllers</div>
      {% for comp in ctrlComps %}
        <a href="/components/{{ comp.name }}/" class="nav-item {% if currentSlug == comp.name %}active{% endif %}">{{ comp.name }}</a>
      {% endfor %}
    {% endif %}

    {% set modelComps = allComps | byCategory("model") %}
    {% if modelComps.length %}
      <div class="nav-section-label">Models</div>
      {% for comp in modelComps %}
        <a href="/components/{{ comp.name }}/" class="nav-item {% if currentSlug == comp.name %}active{% endif %}">{{ comp.name }}</a>
      {% endfor %}
    {% endif %}

    {% set utilComps = allComps | byCategory("util") %}
    {% if utilComps.length %}
      <div class="nav-section-label">Utils</div>
      {% for comp in utilComps %}
        <a href="/components/{{ comp.name }}/" class="nav-item {% if currentSlug == comp.name %}active{% endif %}">{{ comp.name }}</a>
      {% endfor %}
    {% endif %}

    {% set otherComps = allComps | byCategory("other") %}
    {% if otherComps.length %}
      <div class="nav-section-label">Other</div>
      {% for comp in otherComps %}
        <a href="/components/{{ comp.name }}/" class="nav-item {% if currentSlug == comp.name %}active{% endif %}">{{ comp.name }}</a>
      {% endfor %}
    {% endif %}

  </nav>

  <main class="main">
    {{ content | safe }}
  </main>

</div>
</body>
</html>
