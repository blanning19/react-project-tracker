    "setSessionExpiredHandler": {
      "name": "setSessionExpiredHandler",
      "isComponent": false,
      "isHook": false,
      "isDefault": false,
      "jsDoc": {
        "description": "Registers a callback that is invoked when the user's session has expired and cannot be silently renewed. Call this once from `AuthProvider` on mount so the HTTP layer can trigger a React-side logout and redirect to `/login` without coupling this module to React hooks or the router. The callback is called after `tokenStore.clear()` has already run, so the handler only needs to update React state (e.g. clear `accessToken`) and navigate — it does not need to clear tokens itself.",
        "tags": {
          "param": [
            "handler - Zero-argument function to invoke on session expiry,",
            "or `null` to deregister the current handler."
          ],
          "example": [
            "```ts",
            "// Inside AuthProvider useEffect:",
            "setSessionExpiredHandler(handleSessionExpired);",
            "return () => setSessionExpiredHandler(null);",
            "```"
          ]
        }
