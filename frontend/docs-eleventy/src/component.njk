---
layout: layout.njk
pagination:
  data: collections.components
  size: 1
  alias: comp
permalink: /components/{{ comp.name }}/
---

{# Make the current slug available to the layout for nav highlighting #}
{% set currentSlug = comp.name %}
{% set title = comp.name %}

{# ── Breadcrumb ───────────────────────────────────────────────── #}
<div class="breadcrumb">
  <a href="/">Overview</a>
  <span>/</span>
  <span>{{ comp.file }}</span>
  <span>/</span>
  <span>{{ comp.name }}</span>
</div>

{# ── Header ───────────────────────────────────────────────────── #}
<div class="comp-header">
  <div class="comp-badges">
    {% if comp.isComponent %}
      <span class="badge badge-component">component</span>
    {% endif %}
    {% if comp.isHook %}
      <span class="badge badge-hook">hook</span>
    {% endif %}
    {% if not comp.isComponent and not comp.isHook %}
      <span class="badge badge-util">utility</span>
    {% endif %}
    {% if comp.isDefault %}
      <span class="badge badge-default">default export</span>
    {% endif %}
    {% if comp.viewPanels.length %}
      {% set totalPanelChildren = 0 %}
      {% for vp in comp.viewPanels %}
        {% set totalPanelChildren = totalPanelChildren + vp.children.length %}
      {% endfor %}
      <span class="badge badge-panel">{{ totalPanelChildren }} view panels</span>
    {% endif %}
  </div>

  <div class="comp-name">{{ comp.name }}</div>
  <div class="comp-file">{{ comp.file }}</div>

  <div class="comp-sig">
    {% if comp.isHook %}
      function {{ comp.name }}()
    {% elif comp.isComponent %}
      function {{ comp.name }}(): JSX.Element
    {% else %}
      {{ comp.name }}
    {% endif %}
  </div>

  {% if comp.jsDoc and comp.jsDoc.description %}
    <div class="comp-desc">{{ comp.jsDoc.description }}</div>
  {% endif %}
</div>

{# ── ViewPanel section ────────────────────────────────────────── #}
{% if comp.viewPanels.length %}
  {% for panel in comp.viewPanels %}
    <div class="section">
      <div class="section-title">
        View panel — {{ panel.children.length }} child component{% if panel.children.length != 1 %}s{% endif %}
        {% if panel.autoDetected %}
          <span class="badge badge-auto" style="margin-left:8px;">auto-detected</span>
        {% endif %}
        {% if panel.line %}
          <span style="margin-left:8px;font-weight:400;opacity:0.5;">line {{ panel.line }}</span>
        {% endif %}
      </div>
      <div class="panel-grid">
        {% for child in panel.children %}
          {% if components.components[child.name] %}
            <a href="/components/{{ child.name }}/" class="panel-card">
              <div class="panel-card-number">Panel {{ loop.index }}</div>
              <div class="panel-card-name">{{ child.name }}</div>
              {% if child.importPath %}
                <div class="panel-card-path">{{ child.importPath }}</div>
              {% endif %}
            </a>
          {% else %}
            <div class="panel-card">
              <div class="panel-card-number">Panel {{ loop.index }}</div>
              <div class="panel-card-name">{{ child.name }}</div>
              {% if child.importPath %}
                <div class="panel-card-path">{{ child.importPath }}</div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endfor %}
{% endif %}

{# ── Internal helpers ─────────────────────────────────────────── #}
{% if comp.internalHelpers.length %}
  <div class="section">
    <div class="section-title">Internal helpers — defined inside {{ comp.name }}</div>
    <div class="helper-list">
      {% for helper in comp.internalHelpers %}
        <div class="helper-item">
          <div class="helper-sig">function {{ helper.name }}()</div>
          <div class="helper-return">returns {{ helper.returnType }}</div>
          {% if helper.jsDoc and helper.jsDoc.description %}
            <div class="helper-desc">{{ helper.jsDoc.description }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

{# ── useEffect calls ──────────────────────────────────────────── #}
{% if comp.effects.length %}
  <div class="section">
    <div class="section-title">
      useEffect — {{ comp.effects.length }} effect{% if comp.effects.length != 1 %}s{% endif %}
    </div>
    <div class="effect-list">
      {% for effect in comp.effects %}
        <div class="effect-item">
          {% if effect.isMount %}
            <span class="effect-mount">Runs once on mount</span>
          {% elif effect.deps == null %}
            <span>Runs on every render</span>
          {% else %}
            <span>Deps: <span class="effect-deps">[{{ effect.deps | join(", ") }}]</span></span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

{# ── Hooks used ───────────────────────────────────────────────── #}
{% if comp.hooksUsed.length %}
  <div class="section">
    <div class="section-title">Hooks used</div>
    <div class="hook-chips">
      {% for hook in comp.hooksUsed %}
        {% if components.components[hook] %}
          <a href="/components/{{ hook }}/" class="hook-chip">{{ hook }}</a>
        {% else %}
          <span class="hook-chip">{{ hook }}</span>
        {% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}

{# ── JSDoc tags ───────────────────────────────────────────────── #}
{% if comp.jsDoc and comp.jsDoc.tags %}
  <div class="section">
    <div class="section-title">JSDoc tags</div>
    <div class="import-list">
      {% for key, lines in comp.jsDoc.tags %}
        <div class="import-item">
          <span class="import-source">@{{ key }}</span>
          <span class="import-specifiers">{{ lines | join(" ") }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

{# ── Internal imports ─────────────────────────────────────────── #}
{% set internalImports = [] %}
{% for imp in comp.imports %}
  {% if imp.source | startsWith(".") or imp.source | startsWith("@/") %}
    {% set internalImports = (internalImports.push(imp), internalImports) %}
  {% endif %}
{% endfor %}

{% if internalImports.length %}
  <div class="section">
    <div class="section-title">Internal imports</div>
    <div class="import-list">
      {% for imp in internalImports %}
        <div class="import-item">
          <span class="import-source">{{ imp.source }}</span>
          <span class="import-specifiers">{{ imp.specifiers | join(", ") }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

{# ── External imports ─────────────────────────────────────────── #}
{% set externalImports = [] %}
{% for imp in comp.imports %}
  {% if not (imp.source | startsWith(".")) and not (imp.source | startsWith("@/")) %}
    {% set externalImports = (externalImports.push(imp), externalImports) %}
  {% endif %}
{% endfor %}

{% if externalImports.length %}
  <div class="section">
    <div class="section-title">External imports</div>
    <div class="import-list">
      {% for imp in externalImports %}
        <div class="import-item">
          <span class="import-source">{{ imp.source }}</span>
          <span class="import-specifiers">{{ imp.specifiers | join(", ") }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}
