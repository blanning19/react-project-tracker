---
layout: layout.njk
title: Overview
permalink: /
---

<div class="breadcrumb">
  <span>Source Docs</span>
</div>

<div class="comp-header">
  <div class="comp-name" style="font-size:1.6em;">ICT Dashboard</div>
  <div class="comp-desc">
    Auto-generated from source. Every component, hook, utility, and internal helper
    extracted directly from inside your function bodies.
    Last parsed: {{ components.generatedAt | dateFormat }}.
  </div>
</div>

{% set allComps = components.components | values %}
{% set componentCount = allComps | where("isComponent", true) %}
{% set hookCount = allComps | where("isHook", true) %}

<div class="stats-bar">
  <div class="stat">
    <div class="stat-value">{{ components.totalFiles }}</div>
    <div class="stat-label">Files</div>
  </div>
  <div class="stat">
    <div class="stat-value">{{ componentCount.length }}</div>
    <div class="stat-label">Components</div>
  </div>
  <div class="stat">
    <div class="stat-value">{{ hookCount.length }}</div>
    <div class="stat-label">Hooks</div>
  </div>
  <div class="stat">
    <div class="stat-value">{{ components.totalComponents }}</div>
    <div class="stat-label">Total exports</div>
  </div>
</div>

{% set pageComps = allComps | byCategory("page") %}
{% if pageComps.length %}
  <div class="section">
    <div class="overview-section-title">Pages</div>
    <div class="index-grid">
      {% for comp in pageComps %}
        <a href="/components/{{ comp.name }}/" class="index-card">
          <div class="index-card-name">{{ comp.name }}</div>
          <div class="index-card-file">{{ comp.file }}</div>
          {% if comp.jsDoc and comp.jsDoc.description %}
            <div class="index-card-desc">{{ comp.jsDoc.description | truncate(100) }}</div>
          {% endif %}
          {% if comp.viewPanels and comp.viewPanels.length %}
            <div style="margin-top:8px;">
              <span class="badge badge-panel">{{ comp.viewPanels[0].children.length }} panels</span>
            </div>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
{% endif %}

