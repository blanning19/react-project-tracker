{
    "$schema": "https://typedoc.org/schema.json",

    "entryPointStrategy": "expand",
    "entryPoints": [
        "src/main.tsx",
        "src/App.tsx",
        "src/shared",
        "src/features"
    ],

    "out": "docs",

    "name": "Project Tracker",
    "readme": "README.md",

    "includeVersion": true,

    "categorizeByGroup": true,
    "defaultCategory": "Other",
    "categoryOrder": [
        "Auth",
        "HTTP",
        "Projects",
        "Home",
        "Other"
    ],

    "excludePrivate": true,
    "excludeInternal": true,
    "excludeExternals": true,

    "exclude": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/__tests__/**",
        "**/*.module.css",
        "**/setupTests.*",
        "**/vite-env.d.ts"
    ],

    "blockTags": [
        "@file",
        "@module",
        "@param",
        "@returns",
        "@example",
        "@remarks",
        "@typeParam",
        "@throws",
        "@deprecated",
        "@internal",
        "@default"
    ],

    "highlightLanguages": [
        "typescript",
        "tsx",
        "javascript",
        "jsx",
        "json",
        "bash",
        "powershell",
        "css"
    ],

    "navigationLinks": {
        "GitHub": "https://github.com/blanning19/react-project-tracker"
    },

    "plugin": [],

    "tsconfig": "tsconfig.json"
}